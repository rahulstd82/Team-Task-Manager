{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "Team Task Manager API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp -r src/db/migrations dist/db/migrations && npm run build:client",
    "build:client": "cd client && npm install && npm run build",
    "start": "node -r dotenv/config dist/db/migrate.js && node -r dotenv/config dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "migrate:prod": "node -r dotenv/config dist/db/migrate.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
